{
  "name": "aspargolabs-demo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "vapi:export": "dotenv -e .env.local -e .env -- node scripts/vapi-export-assistants.mjs",
    "vapi:sync": "dotenv -e .env.local -e .env -- node scripts/vapi-sync-assistants.mjs",
    "vapi:sync-tools": "dotenv -e .env.local -e .env -- node scripts/vapi-sync-tools.mjs",
    "db:gen-types": "dotenv -e .env.local -e .env -- sh -c \"npx supabase gen types typescript --project-id \\\"$SUPABASE_PROJECT_ID\\\" > types/database.types.ts\"",
    "db:migrate": "dotenv -e .env.local -e .env -- npx supabase db push",
    "db:reset": "dotenv -e .env.local -e .env -- npx supabase db reset"
  },
  "dependencies": {
    "@ai-sdk/groq": "^3.0.35",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.0",
    "@vapi-ai/web": "^2.5.2",
    "ai": "^6.0.168",
    "gsap": "^3.15.0",
    "lucide-react": "^1.11.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "supabase": "^2.0.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^8.0.10",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5"
  }
}
